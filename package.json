{
  "name": "glyph3d",
  "version": "1.0.6",
  "description": "A 3D engine that renders with ASCII characters instead of pixels.",
  "main": "dist/src/index.js",
  "module": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src"
  ],
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky && npm run build"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "3d",
    "ascii",
    "rendering",
    "engine",
    "canvas",
    "graphics",
    "typescript"
  ],
  "author": "FRQ-ALS <farooqalsaadi0@gmail.com>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FRQ-ALS/glyph3d.git"
  },
  "homepage": "https://github.com/FRQ-ALS/glyph3d#readme",
  "bugs": {
    "url": "https://github.com/FRQ-ALS/glyph3d/issues"
  },
  "type": "module",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1"
  }
}
